# Maintainer: kalzEOS <kalzwayed@gmail.com>
pkgname=cursorforge
pkgver=0.1.2
pkgrel=1
pkgdesc="Add extra sizes to installed Xcursor themes"
arch=('any')
url="https://github.com/kalzEOS/CursorForge"
license=('GPL-3.0-or-later')
depends=(
    'python'
    'python-pyside6'
    'xcur2png'
    'xorg-xcursorgen'
    'imagemagick'
)
makedepends=(
    'python-build'
    'python-installer'
    'python-hatchling'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/kalzEOS/CursorForge/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "CursorForge-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "CursorForge-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 assets/cursorforge.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/cursorforge.svg"
    install -Dm644 packaging/cursorforge.desktop \
        "$pkgdir/usr/share/applications/cursorforge.desktop"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
